[0.0,"o","# Hello Video\r\n\r\n```yaml studio-directive\r\n"]
[0.0,"o","scene: Hello Video\r\n```\r\n\r\n```yaml studio-directive\r\nbeat:\r\n  id: hello\r\n  heading: Say Hello\r\n  narration: Print one line in the terminal.\r\n  caption: A one-command terminal recording.\r\n  actions:\r\n  - commands:\r\n    - run_file: hello/hello.sh\r\n      display: bash hello/hello.sh\r\n```\r\n"]
