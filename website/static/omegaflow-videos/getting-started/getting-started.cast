[0.035, "o", "\r\n\u001b[36;1m# Inspect the configured publish surfaces.\u001b[0m\r\n\r\n"]
[0.511, "o", "Build dry run: Hello Video\r\n\r\n"]
[0.000, "o", "Inputs:\r\n"]
[0.000, "o", "  recording_script: recordings/hello/omegaflow.md\r\n  recording_source: recordings/hello/omegaflow.md\r\n\r\n"]
[0.000, "o", "Outputs:\r\n  baseline_cast: recordings/.omegaflow/runs/.scratch/build/hello/20260707-152629/recording.cast\r\n"]
[0.000, "o", "  timeline: recordings/.omegaflow/runs/.scratch/build/hello/20260707-152629/recording.timeline.jsonl\r\n  recording_fingerprint: recordings/.omegaflow/runs/.scratch/build/hello/20260707-152629/recording.fingerprint.json\r\n  audio_fragments: recordings/.omegaflow/cache/audio/hello/*.mp3\r\n"]
[0.000, "o", "  voiceover: recordings/.omegaflow/runs/.scratch/build/hello/20260707-152629/audio/hello.mp3\r\n  audio_metadata: recordings/.omegaflow/runs/.scratch/build/hello/20260707-152629/audio/hello.json\r\n  retimed_cast: recordings/.omegaflow/runs/.scratch/build/hello/20260707-152629/recording.retimed.cast\r\n\r\nPublish surfaces:\r\n"]
[0.000, "o", "  docs:\r\n"]
[0.000, "o", "    type: docusaurus_mdx\r\n    file: docs/hello.md\r\n"]
[0.000, "o", "    placeholder: hello-video\r\n  html:\r\n    type: standalone_html\r\n    file: site/videos/hello.html\r\n\r\nPublish targets:\r\n  baseline_cast: site/videos/hello.cast\r\n"]
[0.001, "o", "  timeline: site/videos/hello.timeline.jsonl\r\n  recording_fingerprint: site/videos/hello.recording.json\r\n  voiceover: website/static/audio/casts/hello.mp3\r\n  audio_metadata: website/static/audio/casts/hello.json"]
[0.000, "o", "\r\n"]
[0.000, "o", "  retimed_cast: site/videos/hello.retimed.cast\r\n"]
[0.000, "o", "\r\nPipeline:\r\n"]
[0.000, "o", "  1. record (compile): record a fast terminal baseline and timeline sidecar"]
[0.000, "o", "\r\n"]
[0.000, "o", "  2. audio_generate (compile): generate or reuse cached TTS fragments for each beat\r\n  3. audio_publish (link): concatenate voiceover and write audio timing metadata\r\n"]
[0.000, "o", "  4. retime (optimize): create the watchable cast using terminal and audio timing\r\n"]
[0.000, "o", "  5. publish_surface (link): embed the finished recording in the selected publish surface\r\n  6. align_check (validate): verify visible captions and commands still match the script\r\n\r\n"]
[0.000, "o", "No commands were run.\r\n"]
[0.048, "o", "\r\n"]
