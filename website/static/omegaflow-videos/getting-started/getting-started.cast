[0.036, "o", "\r\n\u001b[36;1m# Inspect the configured publish surfaces.\u001b[0m\r\n\r\n"]
[0.464, "o", "Build dry run: Hello Video\r\n\r\n"]
[0.000, "o", "Inputs:\r\n  recording_script: studio/recordings/hello.md\r\n"]
[0.000, "o", "  recording_source: studio/recordings/hello.md"]
[0.000, "o", "\r\n"]
[0.000, "o", "\r\nOutputs:\r\n  baseline_cast: studio/runs/.scratch/build/hello/20260706-191724/recording.cast\r\n"]
[0.000, "o", "  timeline: studio/runs/.scratch/build/hello/20260706-191724/recording.timeline.jsonl\r\n  recording_fingerprint: studio/runs/.scratch/build/hello/20260706-191724/recording.fingerprint.json\r\n  audio_fragments: studio/cache/audio/hello/*.mp3\r\n  voiceover: studio/runs/.scratch/build/hello/20260706-191724/audio/hello.mp3"]
[0.000, "o", "\r\n  audio_metadata: studio/runs/.scratch/build/hello/20260706-191724/audio/hello.json\r\n  retimed_cast: studio/runs/.scratch/build/hello/20260706-191724/recording.retimed.cast\r\n\r\nPublish surfaces:\r\n"]
[0.000, "o", "  docs:\r\n    type: docusaurus_mdx\r\n"]
[0.000, "o", "    file: docs/hello.md\r\n"]
[0.000, "o", "    placeholder: hello-video\r\n"]
[0.000, "o", "  html:\r\n    type: standalone_html\r\n"]
[0.000, "o", "    file: site/videos/hello.html\r\n"]
[0.000, "o", "\r\nPublish targets:\r\n  baseline_cast: site/videos/hello.cast\r\n  timeline: site/videos/hello.timeline.jsonl\r\n  recording_fingerprint: site/videos/hello.recording.json"]
[0.000, "o", "\r\n  voiceover: website/static/audio/casts/hello.mp3\r\n  audio_metadata: website/static/audio/casts/hello.json\r\n  retimed_cast: site/videos/hello.retimed.cast"]
[0.000, "o", "\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "Pipeline:\r\n  1. record (compile): record a fast terminal baseline and timeline sidecar\r\n"]
[0.000, "o", "  2. audio_generate (compile): generate or reuse cached TTS fragments for each beat\r\n  3. audio_publish (link): concatenate voiceover and write audio timing metadata\r\n"]
[0.000, "o", "  4. retime (optimize): create the watchable cast using terminal and audio timing\r\n  5. publish_surface (link): embed the finished recording in the selected publish surface\r\n  6. align_check (validate): verify visible captions and commands still match the script"]
[0.000, "o", "\r\n"]
[0.000, "o", "\r\nNo commands were run.\r\n"]
