[0.000, "o", "  baseline_cast: .omegaflow/runs/.scratch/build/hello/20260707-004945/recording.cast\r\n"]
[0.000, "o", "  timeline: .omegaflow/runs/.scratch/build/hello/20260707-004945/recording.timeline.jsonl\r\n  recording_fingerprint: .omegaflow/runs/.scratch/build/hello/20260707-004945/recording.fingerprint.json\r\n  audio_fragments: .omegaflow/cache/audio/hello/*.mp3\r\n  voiceover: .omegaflow/runs/.scratch/build/hello/20260707-004945/audio/hello.mp3\r\n"]
[0.000, "o", "  audio_metadata: .omegaflow/runs/.scratch/build/hello/20260707-004945/audio/hello.json\r\n"]
