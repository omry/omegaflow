[0.250, "o", "\r\n\u001b[36;1m# Install the Studio CLI.\u001b[0m\r\n\r\n"]
[0.250, "o", "Successfully installed omegaflow-studio\r\n"]
[0.023, "o", "\r\n"]
[0.034, "o", "\r\n\u001b[36;1m# Create a one-command Studio recording.\u001b[0m\r\n\r\n"]
[0.243, "o", "Wrote /tmp/omegaflow-hello/recordings/config.yaml\r\nWrote /tmp/omegaflow-hello/recordings/hello.md\r\nWrote /tmp/omegaflow-hello/recordings/hello/hello.sh\r\nWrote /tmp/omegaflow-hello/docs/hello.md\r\n"]
[0.202, "o", "/tmp/omegaflow-hello/docs/hello.md\r\n/tmp/omegaflow-hello/recordings/config.yaml\r\n/tmp/omegaflow-hello/recordings/hello.md\r\n/tmp/omegaflow-hello/recordings/hello/hello.sh\r\n"]
[0.219, "o", "---\r\nid: hello\r\ntitle: Hello Video\r\noutputs:\r\n  cast: site/videos/hello.cast\r\npublish:\r\n"]
[0.000, "o", "  default: docs\r\n"]
[0.000, "o", "  build_surfaces:\r\n"]
[0.000, "o", "  - docs\r\n"]
[0.000, "o", "  - html"]
[0.000, "o", "\r\n"]
[0.000, "o", "  surfaces:\r\n    docs:\r\n"]
[0.000, "o", "      type: docusaurus_mdx\r\n      file: docs/hello.md\r\n      placeholder: hello-video\r\n      component: OmegaFlowVideo\r\n    html:\r\n      type: standalone_html\r\n      file: site/videos/hello.html\r\n"]
[0.000, "o", "---\r\n\r\n"]
[0.000, "o", "# Hello Video\r\n\r\n```yaml studio-directive\r\n"]
[0.000, "o", "scene: Hello Video\r\n```\r\n\r\n```yaml studio-directive\r\nbeat:\r\n  id: hello\r\n  heading: Say Hello\r\n  narration: Print one line in the terminal.\r\n  caption: A one-command terminal recording.\r\n  actions:\r\n  - commands:\r\n    - run_file: hello/hello.sh\r\n      display: bash hello/hello.sh\r\n```\r\n"]
[0.026, "o", "\r\n"]
[0.034, "o", "\r\n\u001b[36;1m# Build the tiny video from the script.\u001b[0m\r\n\r\n"]
[1.372, "o", "pass wrote recording: site/videos/hello.cast\r\npass wrote retimed cast: site/videos/hello.retimed.cast\r\npass wrote publish surface: docs/hello.md\r\npass wrote publish surface: site/videos/hello.html\r\n"]
