{"version":3,"term":{"cols":90,"rows":24},"timestamp":1783336638,"command":"studio recording=getting-started step=session","title":"Getting Started With OmegaFlow Studio"}
[0.246, "o", "\r\n\u001b[36;1m# Install the Studio CLI.\u001b[0m\r\n\r\n"]
[0.259, "o", "Successfully installed omegaflow-studio\r\n"]
[0.024, "o", "\r\n"]
[0.037, "o", "\r\n\u001b[36;1m# Create a one-command Studio recording.\u001b[0m\r\n\r\n"]
[0.254, "o", "Wrote /tmp/omegaflow-hello/studio/conf/config.yaml\r\nWrote /tmp/omegaflow-hello/studio/recordings/hello.md\r\nWrote /tmp/omegaflow-hello/docs/hello.md\r\n"]
[0.232, "o", "/tmp/omegaflow-hello/docs/hello.md\r\n/tmp/omegaflow-hello/studio/conf/config.yaml\r\n/tmp/omegaflow-hello/studio/recordings/hello.md\r\n"]
[0.226, "o", "# Hello Video\r\n\r\n"]
[0.000, "o", "```yaml studio-directive\r\n"]
[0.000, "o", "scene: Hello Video\r\n```\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "```yaml studio-directive\r\nrecording:\r\n"]
[0.000, "o", "  id: hello\r\n  title: Hello Video\r\n"]
[0.000, "o", "  capture:\r\n    window_size: 72x14\r\n    headless: true\r\n    baseline_compressed: true\r\n  outputs:\r\n    cast: site/videos/hello.cast\r\n  publish:\r\n"]
[0.000, "o", "    default: docs\r\n"]
[0.000, "o", "    build_surfaces:\r\n"]
[0.000, "o", "    - docs\r\n    - html\r\n    surfaces:\r\n"]
[0.000, "o", "      docs:\r\n        type: docusaurus_mdx\r\n"]
[0.000, "o", "        file: docs/hello.md\r\n"]
[0.000, "o", "        placeholder: hello-video\r\n        component: OmegaFlowVideo\r\n      html:\r\n"]
[0.000, "o", "        type: standalone_html\r\n"]
[0.000, "o", "        file: site/videos/hello.html\r\n  audio:\r\n    enabled: false\r\n    provider: openai\r\n"]
[0.000, "o", "    env: OPENAI_OMEGAFLOW_API_KEY\r\n    model: gpt-4o-mini-tts\r\n"]
[0.000, "o", "    voice: marin\r\n    format: mp3\r\n"]
[0.000, "o", "```\r\n\r\n```yaml studio-directive\r\nbeat:\r\n"]
[0.000, "o", "  id: hello\r\n"]
[0.000, "o", "  heading: Say Hello\r\n  narration: Print one line in the terminal.\r\n  caption: A one-command terminal recording.\r\n  actions:\r\n  - commands:\r\n    - run: printf 'hello from OmegaFlow\\n'\r\n"]
[0.000, "o", "```\r\n"]
[0.027, "o", "\r\n"]
[0.037, "o", "\r\n\u001b[36;1m# Build the tiny video from the script.\u001b[0m\r\n\r\n"]
[1.347, "o", "pass wrote recording: site/videos/hello.cast\r\npass wrote retimed cast: site/videos/hello.retimed.cast\r\npass wrote publish surface: docs/hello.md\r\npass wrote publish surface: site/videos/hello.html\r\n"]
[0.024, "o", "\r\n"]
