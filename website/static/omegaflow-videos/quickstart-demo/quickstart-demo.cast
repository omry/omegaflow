[0.040, "o", "\r\n\u001b[36;1m# Inspect the configured publish surface.\u001b[0m\r\n\r\n"]
[0.494, "o", "Build dry run: Quickstart\r\n\r\nInputs:\r\n  recording_script: recordings/quickstart/index.md\r\n  recording_source: recordings/quickstart/index.md\r\n\r\nOutputs:\r\n"]
[0.000, "o", "  baseline_cast: recordings/.omegaflow/runs/.scratch/build/quickstart/20260707-225711/recording.cast\r\n  timeline: recordings/.omegaflow/runs/.scratch/build/quickstart/20260707-225711/recording.timeline.jsonl\r\n  recording_fingerprint: recordings/.omegaflow/runs/.scratch/build/quickstart/20260707-225711/recording.fingerprint.json\r\n  audio_fragments: recordings/.omegaflow/cache/audio/quickstart/*.mp3\r\n"]
[0.000, "o", "  voiceover: recordings/.omegaflow/runs/.scratch/build/quickstart/20260707-225711/audio/quickstart.mp3\r\n  audio_metadata: recordings/.omegaflow/runs/.scratch/build/quickstart/20260707-225711/audio/quickstart.json\r\n  retimed_cast: recordings/.omegaflow/runs/.scratch/build/quickstart/20260707-225711/recording.retimed.cast\r\n\r\nPublish surfaces:\r\n  html:\r\n"]
[0.000, "o", "    type: standalone_html\r\n    file: recordings/.omegaflow/videos/quickstart.html\r\n\r\nPublish targets:\r\n"]
[0.000, "o", "  baseline_cast: recordings/.omegaflow/videos/quickstart.cast\r\n  timeline: recordings/.omegaflow/videos/quickstart.timeline.jsonl\r\n  recording_fingerprint: recordings/.omegaflow/videos/quickstart.recording.json\r\n  voiceover: website/static/audio/casts/quickstart.mp3\r\n  audio_metadata: website/static/audio/casts/quickstart.json\r\n  retimed_cast: recordings/.omegaflow/videos/quickstart.retimed.cast\r\n"]
[0.000, "o", "\r\nPipeline:\r\n  1. record (compile): record a fast terminal baseline and timeline sidecar\r\n  2. audio_generate (compile): generate or reuse cached TTS fragments for each beat\r\n"]
[0.000, "o", "  3. audio_publish (link): concatenate voiceover and write audio timing metadata\r\n  4. retime (optimize): create the watchable cast using terminal and audio timing\r\n"]
[0.000, "o", "  5. publish_surface (link): embed the finished recording in the selected publish surface\r\n"]
[0.000, "o", "  6. align_check (validate): verify visible captions and commands still match the script\r\n\r\n"]
[0.000, "o", "No commands were run.\r\n"]
[0.047, "o", "\r\n"]
