#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
demo_venv="${HOMEPAGE_DEMO_VENV:-}"
if [[ ! -x "$demo_venv/bin/python" ]]; then
  echo "homepage demo environment is not prepared" >&2
  exit 1
fi

if [[ "${1:-}" == "-m" && "${2:-}" == "pip" && "${3:-}" == "install" ]]; then
  exec "$demo_venv/bin/python" -m pip install \
    --disable-pip-version-check \
    --no-build-isolation \
    --no-deps \
    --editable "$repo_root"
fi

exec "$demo_venv/bin/python" "$@"
